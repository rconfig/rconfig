{
    "preset": "laravel",
    "rules": {
        "class_attributes_separation": {
            "elements": {
                "const": "one",
                "method": "one",
                "property": "none",
                "trait_import": "none"
            }
        },
        "concat_space": {
            "spacing": "one"
        },
        "blank_line_before_statement": {
            "statements": [
                "return"
            ]
        },
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    }
}