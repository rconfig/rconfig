###############################################################################
# rConfig V8 Core — Environment Configuration (.env.example)
#
# This file ships sane defaults for a fresh rConfig V8 Core install. Copy it to
# `.env` and adjust the values flagged as [EDIT] below.
#
# Conventions used in this file:
#   [EDIT]        Safe / expected to be changed per deployment.
#   [OPTIONAL]    Only set if you use the related feature.
#   [DO NOT EDIT] Internal / framework value — leave the default unless you
#                 truly know what you are doing. Changing these can break the
#                 application or its deployment pipeline.
###############################################################################


#==============================================================================
# Application
#==============================================================================
# Display name shown in the UI and emails. [EDIT]
APP_NAME="rConfig V8 Core - Network Configuration Management"

# Environment: production | local. [DO NOT EDIT manually]
APP_ENV=production

# Generated by `php artisan key:generate`. [DO NOT EDIT manually]
APP_KEY=

# Enable verbose error output. Keep false in production. [EDIT]
APP_DEBUG=false

# Public URL of this install. [EDIT]
APP_URL="https://SERVER.DOMAIN.LOCAL"

# Absolute path to the active rConfig release. [DO NOT EDIT]
APP_DIR_PATH=/var/www/html/rconfig


#==============================================================================
# Logging
#==============================================================================
# Laravel log channel and level. [EDIT — see config/logging.php for options]
LOG_CHANNEL=daily
LOG_LEVEL=warning

#==============================================================================
# Database
#==============================================================================
# Primary application database. [EDIT]
DB_CONNECTION=mysql
DB_HOST=DBHOST
DB_PORT=3306
DB_DATABASE=DBNAME
DB_USERNAME=DBUSER
DB_PASSWORD=DBPASS

# On-disk location used for docker MySQL storage. [EDIT]
DB_STORAGE_LOCATION=/storage/app/rconfig/mysql


#==============================================================================
# Cache, Queue, Session & Horizon
#==============================================================================
# Drivers — rConfig is tuned for Redis. [DO NOT EDIT unless you know your stack]
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
CACHE_PREFIX=rConfigp

# Horizon (queue worker manager). Tune process counts to match server capacity. [EDIT]
HORIZON_PREFIX=rConfig
HORIZON_LOCAL_TIMEOUT=120
HORIZON_PROD_TIMEOUT=120
HORIZON_MIN_PROCESS=1
HORIZON_MAX_PROCESS=10
HORIZON_DEFAULT_MAX_PROCESS=5

QUEUE_CONNECTION=redis
QUEUE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Must be greater than the longest-running job timeout. [DO NOT EDIT unless tuning queues]
REDIS_QUEUE_RETRY_AFTER=130


#==============================================================================
# Redis
#==============================================================================
# Redis connection. REDIS_HOST_DOCKER is used when running under Docker. [EDIT]
REDIS_HOST_DOCKER=rconfig-redis
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379


#==============================================================================
# Docker Exposed Ports
#==============================================================================
# Host ports published by the Docker deployment. [EDIT if running under Docker]
EXPOSED_APP_PORT=8080
EXPOSED_DB_PORT=3307
EXPOSED_HORIZON_PORT=8081
EXPOSED_REDIS_PORT=7000


#==============================================================================
# Mail
#==============================================================================
# SMTP delivery settings. [EDIT if sending email]
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME=null


#==============================================================================
# rConfig API & Subscription
#==============================================================================
# Subscription / licensing values for the Core edition. [DO NOT EDIT]
RCONFIG_API_TOKEN=V8Core
RCONFIG_SUB_ID="V8Core"
RCONFIG_SUB_NAME="V8Core"
RCONFIG_SUB_STATUS="Active"
RCONFIG_SUB_EXPIRY="N/A"


#==============================================================================
# Localisation
#==============================================================================
# Server timezone — see https://www.php.net/manual/en/timezones.php. [EDIT]
TIMEZONE=Europe/Dublin


#==============================================================================
# Enlightn (security/perf scanner)
#==============================================================================
# [DO NOT EDIT unless you know what you are doing]
ENLIGHTN_SKIP_ENVIRONMENT_SPECIFIC=false


#==============================================================================
# Single Sign-On — Microsoft / Entra ID
#==============================================================================
# Populate these to enable Microsoft / Entra ID social login. [OPTIONAL]
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=


#==============================================================================
# Single Sign-On — Okta
#==============================================================================
# Populate these to enable Okta social login. [OPTIONAL]
OKTA_BASE_URL=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=


#==============================================================================
# Credential Display
#==============================================================================
# Mask device credentials in the UI for non-privileged operators. [EDIT]
MASK_DEVICE_CREDENTIALS=false


#==============================================================================
# Health Check Ping Behaviour
#==============================================================================
# Connectivity ping checks. Uncomment to override the defaults. [OPTIONAL]
# Disable all connectivity ping checks:
# HEALTHCHECK_PING_ENABLED=false
# Mark environment as offline/isolated and automatically skip ping checks:
# HEALTHCHECK_OFFLINE_MODE=true
# HEALTHCHECK_AIR_GAPPED=true
# Use an internal-only target (localhost/gateway/internal URL):
# HEALTHCHECK_PING_TARGET=http://127.0.0.1
# HEALTHCHECK_PING_TIMEOUT=5


#==============================================================================
# SAML2 / Shibboleth SSO
#==============================================================================
# Enterprise SSO via SAML2. [OPTIONAL]
SAML2_METADATA_URL=
SAML2_SP_CERTIFICATE=
SAML2_SP_PRIVATE_KEY=
