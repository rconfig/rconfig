parameters:
	ignoreErrors:
		-
			message: '#^Called ''where'' on Laravel collection, but could have been retrieved as a query\.$#'
			identifier: larastan.noUnnecessaryCollectionCall
			count: 1
			path: app/Console/Commands/Reports/ReportLastDownloadCmd.php

		-
			message: '#^Function snmp_trap_path not found\.$#'
			identifier: function.notFound
			count: 1
			path: app/Console/Commands/Snmp/ManageSnmpTrapRegistry.php

		-
			message: '#^Static call to instance method Prism\\Prism\\Prism\:\:text\(\)\.$#'
			identifier: method.staticCall
			count: 1
			path: app/Http/Controllers/Api/ChatAIController.php

		-
			message: '#^Access to an undefined property App\\Http\\Controllers\\Api\\EocRecheckController\:\:\$model\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/Api/EocRecheckController.php

		-
			message: '#^Access to an undefined property App\\Http\\Controllers\\Api\\EocRecheckController\:\:\$modelname\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/Api/EocRecheckController.php

		-
			message: '#^Called ''Model\:\:make\(\)'' which performs unnecessary work, use ''new Model\(\)''\.$#'
			identifier: larastan.noModelMake
			count: 1
			path: app/Http/Controllers/Api/SettingEmailController.php

		-
			message: '#^Method App\\Http\\Controllers\\Api\\SettingsPurgeController\:\:destroy\(\) should return Illuminate\\Http\\Response but return statement is missing\.$#'
			identifier: return.missing
			count: 1
			path: app/Http/Controllers/Api/SettingsPurgeController.php

		-
			message: '#^Access to undefined constant Illuminate\\Support\\Facades\\Response\:\:HTTP_NOT_FOUND\.$#'
			identifier: classConstant.notFound
			count: 1
			path: app/Http/Controllers/Api/UserController.php

		-
			message: '#^Access to an undefined property App\\Http\\Controllers\\Api\\v1\\ConfigsController\:\:\$query\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/Api/v1/ConfigsController.php

		-
			message: '#^Instantiated class App\\DataTransferObjects\\StoreSnmpResultDTO not found\.$#'
			identifier: class.notFound
			count: 1
			path: app/Http/Requests/StoreSnmpResultRequest.php

		-
			message: '#^Method App\\Http\\Requests\\StoreSnmpResultRequest\:\:toDTO\(\) has invalid return type App\\DataTransferObjects\\StoreSnmpResultDTO\.$#'
			identifier: class.notFound
			count: 1
			path: app/Http/Requests/StoreSnmpResultRequest.php

		-
			message: '#^Called ''pluck'' on Laravel collection, but could have been retrieved as a query\.$#'
			identifier: larastan.noUnnecessaryCollectionCall
			count: 2
			path: app/Models/ConfigChange.php

		-
			message: '#^Unsafe usage of new static\(\)\.$#'
			identifier: new.static
			count: 1
			path: app/Models/User.php

		-
			message: '#^Class App\\Services\\Snmp\\Traps\\SnmpTrapServices\\DeviceResolverService not found\.$#'
			identifier: class.notFound
			count: 4
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Class App\\Services\\Snmp\\Traps\\SnmpTrapServices\\SnmpTrapParser not found\.$#'
			identifier: class.notFound
			count: 2
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Class App\\Services\\Snmp\\Traps\\SnmpTrapServices\\TrapFilterService not found\.$#'
			identifier: class.notFound
			count: 7
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Class App\\Services\\Snmp\\Traps\\SnmpTrapServices\\TrapLoggingService not found\.$#'
			identifier: class.notFound
			count: 2
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Class App\\Services\\Snmp\\Traps\\SnmpTrapServices\\TrapProcessorService not found\.$#'
			identifier: class.notFound
			count: 1
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Class App\\Services\\Snmp\\Traps\\TrapProcessor not found\.$#'
			identifier: class.notFound
			count: 1
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Instantiated class App\\Services\\Snmp\\Traps\\SnmpTrapServices\\TrapProcessorService not found\.$#'
			identifier: class.notFound
			count: 1
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Instantiated class App\\Services\\Snmp\\Traps\\TrapProcessor not found\.$#'
			identifier: class.notFound
			count: 1
			path: app/Providers/SnmpTrapServiceProvider.php

		-
			message: '#^Relation ''agent'' is not found in App\\Models\\Task model\.$#'
			identifier: larastan.relationExistence
			count: 1
			path: app/Services/Connections/GetAndCheckTaskIds.php

		-
			message: '#^Undefined variable\: \$result$#'
			identifier: variable.undefined
			count: 2
			path: app/Services/Connections/Telnet/SendCommand.php

		-
			message: '#^Class App\\Services\\DeviceLoaders\\requests\\StoreDeviceRequest referenced with incorrect case\: App\\Services\\DeviceLoaders\\Requests\\StoreDeviceRequest\.$#'
			identifier: class.nameCase
			count: 1
			path: app/Services/DeviceLoaders/UiDeviceLoadStrategy.php

		-
			message: '#^Relation ''agent'' is not found in App\\Models\\Device model\.$#'
			identifier: larastan.relationExistence
			count: 1
			path: app/Services/DeviceProfiles/DeviceProfileInferenceService.php

		-
			message: '#^Relation ''agent'' is not found in App\\Models\\DeviceProfile model\.$#'
			identifier: larastan.relationExistence
			count: 1
			path: app/Services/DeviceProfiles/DeviceProfileInferenceService.php

		-
			message: '#^Call to an undefined method App\\Services\\Integrations\\Zbx\\Zbx5\\HostGroupTagAppender\:\:fixSequenceAndRetry\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: app/Services/Integrations/Zbx/Zbx5/HostGroupTagAppender.php

		-
			message: '#^Called ''env'' outside of the config directory which returns null when the config is cached, use ''config''\.$#'
			identifier: larastan.noEnvCallsOutsideOfConfig
			count: 6
			path: app/Support/Saml/SamlConfigResolver.php
		# Pro-shared latent issues surfaced by the level 1 upgrade. These same call sites exist
		# unfixed in ../rconfig8 (Pro); fixing them here would change runtime behaviour and diverge
		# Core from Pro, so they are baselined pending a coordinated fix across both editions.
		-
			message: '#^Call to an undefined method App\\Http\\Controllers\\Api\\DashboardController\:\:checkOrSetAppUrlNotification\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: app/Http/Controllers/Api/DashboardController.php

		-
			message: '#^Class Spatie\\Health\\ResultStores\\StoredCheckResults\\StoredCheckResult constructor invoked with 7 parameters, 1\-6 required\.$#'
			identifier: arguments.count
			count: 1
			path: app/Http/Controllers/Api/SystemHealthController.php

		-
			message: '#^Method App\\Http\\Controllers\\Api\\ApiBaseController\:\:show\(\) invoked with 4 parameters, 1\-3 required\.$#'
			identifier: arguments.count
			count: 1
			path: app/Http/Controllers/Api/TagController.php

		-
			message: '#^Static method Spatie\\QueryBuilder\\AllowedFilter\:\:custom\(\) invoked with 4 parameters, 2\-3 required\.$#'
			identifier: arguments.count
			count: 1
			path: app/Http/Controllers/Api/TaskController.php
